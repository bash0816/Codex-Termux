#!/usr/bin/env sh
set -eu

SELF="$0"
while [ -L "${SELF}" ]; do
  DIR=$(CDPATH= cd -- "$(dirname -- "${SELF}")" && pwd)
  TARGET=$(readlink "${SELF}")
  case "${TARGET}" in
    /*) SELF="${TARGET}" ;;
    *) SELF="${DIR}/${TARGET}" ;;
  esac
done

PACKAGE_DIR=$(CDPATH= cd -- "$(dirname -- "${SELF}")/.." && pwd)

if [ -n "${MAGI_NODE:-}" ]; then
  if [ ! -f "${MAGI_NODE}" ] || [ ! -x "${MAGI_NODE}" ]; then
    echo "MAGI_NODE is not an executable file: ${MAGI_NODE}" >&2
    exit 126
  fi
  NODE="${MAGI_NODE}"
else
  NODE=node
fi

exec "$NODE" "${PACKAGE_DIR}/bin/codex.js" "$@"
